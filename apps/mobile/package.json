{
  "name": "@kyc/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --go",
    "start:dev-client": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --dev-client",
    "android": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --go --android",
    "ios": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --go --ios",
    "build:apk": "eas build --profile preview --platform android",
    "build:apk:prod": "eas build --profile production --platform android",
    "eas-build-post-install": "pnpm -C ../../packages/validation run build && pnpm -C ../../packages/api-client run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kyc/api-client": "workspace:*",
    "@kyc/validation": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.7",
    "expo-camera": "^57.0.3",
    "expo-constants": "^57.0.6",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-linking": "^57.0.3",
    "expo-router": "^57.0.7",
    "expo-status-bar": "~57.0.1",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "^2.32.0",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "^0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tailwindcss": "3.4.17",
    "typescript": "~6.0.3"
  }
}
